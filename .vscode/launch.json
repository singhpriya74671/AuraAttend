{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Flask Backend",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/backend/run.py",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "FLASK_ENV": "development",
        "FLASK_DEBUG": "1"
      },
      "envFile": "${workspaceFolder}/backend/.env"
    }
  ]
}
